---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  iconName: string;
}

const { title, description, iconName } = Astro.props;
---

<div class="services">
    <div class="servicesInner">
        <div class="servicesHeader">
            <div class="servicesHeaderIcon">
                <Icon name={iconName} size="28" />
            </div>
            <div class="servicesHeaderText">{title}</div>
        </div>
        <div class="servicesDivider"></div>
        <div class="servicesContent">
            <div class="servicesContentText">
                {description}
            </div>
        </div>
    </div>
    <div class="servicesHoverLine"></div>
</div>

<style>
    .services {
        width: 48%;
        min-height: 280px;
        box-shadow: 10px 10px 1px black;
        border-radius: 1.2rem;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s ease, transform 0.3s ease;
        cursor: default;
    }

    .services:hover {
        border-color: #555;
        transform: translateY(-4px);
    }

    .services:hover .servicesHoverLine {
        width: 100%;
    }

    .servicesHoverLine {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 2px;
        width: 0%;
        background: linear-gradient(90deg, #fff, transparent);
        transition: width 0.5s ease;
    }

    .servicesInner {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        flex: 1;
    }

    .servicesHeader {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .servicesHeaderIcon {
        width: 3rem;
        height: 3rem;
        border-radius: 0.7rem;
        background-color: #1a1a1a;
        border: 0.1rem solid #333;
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        flex-shrink: 0;
    }

    .servicesHeaderText {
        font-family: 'Lexend', sans-serif;
        font-size: 1.5rem;
        color: white;
        font-weight: 700;
        color: black;
    }

    .servicesDivider {
        width: 100%;
        height: 0.05rem;
        background-color: #2a2a2a;
    }

    .servicesContent {
        flex: 1;
    }

    .servicesContentText {
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        color: #3b3b3b;
        line-height: 1.7;
    }

    @media screen and (max-width: 768px) {
        .services {
            width: 100%;
        }
        .servicesHeaderText {
            font-size: 1.3rem;
        }
    }
    @media screen and (min-width : 600px) and (max-width : 1000px){
        .services{
            width: 90%;
            height: 95%;
        }
    }
</style>