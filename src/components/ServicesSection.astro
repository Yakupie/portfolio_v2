---
import Services from "./Services.astro";
---

<section class="section4">
  <div class="section4Wrapper">
    <div class="section4Header">Services</div>
    <div class="section4Content">
<Services
        iconName="lucide:code"
        title="Web Development"
        description="We create modern and user-friendly web interfaces. We strengthen your digital presence by developing performance-oriented, SEO-friendly projects that work flawlessly on all devices. Using the latest technologies, we offer fast and reliable software solutions tailored to your brand's needs. Get ready for the future with professional code structure."
      />
      <Services
        iconName="lucide:database"
        title="Data Analysis"
        description="We transform complex datasets into meaningful strategies. We help you make more accurate decisions by optimizing your business processes through database management and in-depth analysis methods. While enabling you to reach your growth targets with our data-driven insights, we maximize your operational efficiency. Plan the future with data."
      />
    </div>
  </div>
</section>

<style>
  .section4 {
    width: 100%;
    height: 50vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .section4Wrapper { width: 80%; height: 90%; }
  .section4Header {
    height: 20%;
    width: 15%;
    font-family: 'Lexend', sans-serif;
    display: flex;
    align-items: center;
    font-size: 3.5rem;
    border-bottom: 0.1rem solid black;
  }
  .section4Content {
    height: 80%;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  @media screen and (max-width: 600px) {
    .section4 { height: 120vh; }
    .section4Wrapper { width: 90%; height: 100%; }
    .section4Content {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      gap: 1rem;
    }
  }
  @media screen and (min-width: 600px) and (max-width: 1000px) {
    .section4 { height: 90vh; }
    .section4Wrapper { width: 90%; height: 100%; }
    .section4Content {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>