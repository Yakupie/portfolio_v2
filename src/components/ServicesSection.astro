---
import Services from "./Services.astro";
---

<section class="section4">
  <div class="section4Wrapper">
    <div class="section4Header">Services</div>
    <div class="section4Content">
      <Services
        iconName="lucide:code"
        title="Web Geliştirme"
        description="Modern ve kullanıcı dostu web arayüzleri oluşturuyoruz. Performans odaklı, SEO uyumlu ve tüm cihazlarda kusursuz çalışan projeler geliştirerek dijital varlığınızı güçlendiriyoruz. En güncel teknolojileri kullanarak markanızın ihtiyaçlarına özel, hızlı ve güvenilir yazılım çözümleri sunuyoruz. Profesyonel kod yapısıyla geleceğe hazır olun."
      />
      <Services
        iconName="lucide:database"
        title="Veri Analizi"
        description="Karmaşık veri setlerini anlamlı stratejilere dönüştürüyoruz. Veritabanı yönetimi ve derinlemesine analiz yöntemleriyle iş süreçlerinizi optimize ederek daha doğru kararlar almanıza yardımcı oluyoruz. Veriye dayalı öngörülerimizle büyüme hedeflerinize ulaşmanızı sağlarken, operasyonel verimliliğinizi en üst düzeye taşıyoruz. Geleceği verilerle planlayın."
      />
    </div>
  </div>
</section>

<style>
  .section4 {
    width: 100%;
    height: 50vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .section4Wrapper { width: 80%; height: 90%; }
  .section4Header {
    height: 20%;
    width: 15%;
    font-family: 'Lexend', sans-serif;
    display: flex;
    align-items: center;
    font-size: 3.5rem;
    border-bottom: 0.1rem solid black;
  }
  .section4Content {
    height: 80%;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  @media screen and (max-width: 600px) {
    .section4 { height: 120vh; }
    .section4Wrapper { width: 90%; height: 100%; }
    .section4Content {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      gap: 1rem;
    }
  }
  @media screen and (min-width: 600px) and (max-width: 1000px) {
    .section4 { height: 90vh; }
    .section4Wrapper { width: 90%; height: 100%; }
    .section4Content {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>