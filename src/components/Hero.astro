---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import mainImage from '../assets/main.webp';
---

<div class="section1Content">
  <div class="section1Wrapper">
    <div class="section1Left">
      <div class="section1LeftTop">
        <div class="work">Available For Work</div>
        <div class="header">Hi, I'm Yakup</div>
        <div class="title">Web Developer - Data Scientist</div>
        <div class="text">Passionate Web Developer with 3+ years of expertise in creating responsive and functional interfaces. My academic journey in Statistics fuels my deep interest in Mathematics and Data Science, allowing me to transform complex data into beautiful, actionable web experiences.</div>
        <div class="location"><Icon name="lucide:map-pin" />Malatya</div>
        <div class="buttons">
          <a href="https://www.linkedin.com/in/yakupdoger/"><button id="hireMe"><Icon name="lucide:arrow-right"/>Hire Me</button></a>
          <a href="../assets/cv.docx" download=""><button id="downloadCv"><Icon name="lucide:download"/>Download CV</button></a>
        </div>
      </div>
    </div>
    <div class="section1Right">
      <Image src={mainImage} alt="Yakup Doğer" quality="mid" loading="eager" class="main-img" />
    </div>
  </div>
</div>

<style>
  .section1Content {
    width: 100%;
    height: 90vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .section1Wrapper {
    width: 80%;
    height: 90%;
    display: flex;
  }
  .section1Left { width: 60%; height: 100%; }
  .section1Right { width: 40%; height: 100%; display: flex; align-items: center; }
  .main-img { width: 70%; height: 70%; }
  .section1LeftTop {
    height: 80%;
    width: 80%;
    display: flex;
    justify-content: center;
    flex-direction: column;
    gap: 1.5rem;
    border-bottom: 0.1rem solid black;
  }
  .header { font-size: 5rem; font-family: 'Lexend', sans-serif; }
  .title { font-size: 1.2rem; letter-spacing: 0.05em; font-family: 'Inter', sans-serif; }
  .text { font-size: 1.2rem; font-family: 'Inter', sans-serif; }
  .location { display: flex; align-items: center; gap: 5px; font-family: 'Inter', sans-serif; }
  .buttons { display: flex; gap: 1rem; }
  .buttons a { text-decoration: none; }
  #hireMe {
    width: 7rem; height: 2.5rem; border-radius: 0.5rem; border: none;
    background-color: black; color: white; display: flex;
    justify-content: center; align-items: center; gap: 3px;
    cursor: pointer; font-family: 'Inter', sans-serif;
  }
  #downloadCv {
    display: flex; justify-content: center; align-items: center;
    background-color: white; border: 0.15rem solid black;
    border-radius: 0.5rem; width: 9rem; gap: 5px;
    height: 2.5rem; cursor: pointer; font-family: 'Inter', sans-serif;
  }
  .work {
    background-color: #f0f0f0; width: 30%; height: 2rem;
    display: flex; justify-content: center; align-items: center;
    letter-spacing: 0.05em; border-radius: 5rem; font-family: 'Inter', sans-serif;
  }

  @media screen and (max-width: 600px) {
    .section1Content { height: 100vh; }
    .section1Right { display: none; }
    .section1Left { width: 100%; }
    .section1LeftTop {
      width: 100%; height: 100%;
      display: flex; justify-content: center; align-items: center; border: none;
    }
    .header { text-align: center; }
    .work { width: 60%; }
    .title { text-align: center; }
    .text { text-align: center; }
  }
  @media screen and (min-width: 600px) and (max-width: 1000px) {
    .section1Content { height: 100vh; }
    .section1Left { width: 100%; display: flex; justify-content: center; align-items: center; }
    .section1Right { display: none; }
    .section1LeftTop { display: flex; justify-content: center; align-items: center; }
    .header { text-align: center; }
    .work { width: 60%; }
  }
  @media screen and (min-width: 1000px) and (max-width: 1300px) {
    .section1Left { width: 50%; }
    .section1Right { width: 50%; display: flex; justify-content: center; align-items: center; }
    .main-img { width: 90%; }
    .header { font-size: 4rem; }
    .section1LeftTop { width: 100%; height: 100%; border: none; }
    .work { width: 50%; }
  }
</style>