---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
    title: string;
    text: string;
    imagePath: ImageMetadata;
}

const { title, text, imagePath } = Astro.props;
---

<div class="project-card">
    <div class="image-container">
        <Image 
    src={imagePath} 
    alt={title} 
    width={300}         
    height={180}         
    widths={[300, 600]}
    sizes="(max-width: 768px) 296px, 300px" 
    loading="lazy"   
    decoding="async"     
    format="avif"
    class="project-image" 
/>
    </div>
    <div class="content-area">
        <h3 class="project-title">{title}</h3>
        <p class="project-description">{text}</p>
    </div>
</div>

<style>
    .project-card {
        width: 320px;
        flex-shrink: 0;
        height: 420px;
        background-color: #f7f7f7;
        box-shadow: 10px 10px 1px black;
        border-radius: 1.5rem;
        overflow: hidden;
        transition: transform 0.3s ease, border-color 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .project-card:hover {
        transform: translateY(-5px);
        border-color: #444;
    }

    .image-container {
        width: 100%;
        height: 200px;
        padding: 0.75rem;
    }

    .project-image {
        width: 100%;
        height: 100%;
        object-position: center;
        border-radius: 1rem;
        filter: grayscale(20%);
        transition: filter 0.3s ease;
        aspect-ratio: 300 / 180;
        object-fit: cover;
    }

    .project-card:hover .project-image {
        filter: grayscale(0%);
    }

    .content-area {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex-grow: 1;
    }

    .project-title {
        font-family: 'Lexend', sans-serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: black;
        margin: 0;
    }

    .project-description {
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        line-height: 1.5;
        color: #3b3b3b;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>