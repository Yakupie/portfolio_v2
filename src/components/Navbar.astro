---
import { Icon } from 'astro-icon/components';
---

<div class="navbar">
  <div class="navbarWrapper">
<ul>
  <li><a href="#home"><Icon name="lucide:home" />Home</a></li>
  <li><a href="#about"><Icon name="lucide:contact-2" />About</a></li>
  <li><a href="#projects"><Icon name="lucide:folder-open" />Projects</a></li>
  <li><a href="#services"><Icon name="lucide:code-2" />Services</a></li>
  <li><a href="#contact"><Icon name="lucide:mail" />Contact</a></li>
  <span class="slider"></span>
</ul>
  </div>
</div>

<style>
  .navbar {
    width: 100%;
    height: 10vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 20px;
  }

  .navbarWrapper {
    width: 100%;
    max-width: 800px;
    height: 60px;
    background: white;
    border-radius: 5rem;
    box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    position: relative;
    padding: 0 10px;
  }

  .navbarWrapper ul {
    display: flex;
    width: 100%;
    height: 100%;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }

  .navbarWrapper ul li {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 2;
  }

  .navbarWrapper ul li a {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: black;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    transition: color 0.3s ease;
    width: 100%;
    height: 100%;
    justify-content: center;
  }

  .slider {
    position: absolute;
    height: 80%;
    top: 10%;
    width: 20%; 
    background-color: black;
    border-radius: 5rem;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    left: 0;
    z-index: 1;
    pointer-events: none;
  }
  .navbarWrapper ul li:first-child a {
    color: white;
  }
  .navbarWrapper ul:hover li a {
    color: black;
  }
  .navbarWrapper ul li:hover a {
    color: white !important;
  }
  .navbarWrapper ul li:nth-child(1):hover ~ .slider { left: 0; }
  .navbarWrapper ul li:nth-child(2):hover ~ .slider { left: 20%; }
  .navbarWrapper ul li:nth-child(3):hover ~ .slider { left: 40%; }
  .navbarWrapper ul li:nth-child(4):hover ~ .slider { left: 60%; }
  .navbarWrapper ul li:nth-child(5):hover ~ .slider { left: 80%; }


  @media screen and (max-width: 800px){
    .navbarWrapper{
        display: none;
    }
    .mobileMenuWrapper{
        background-color: aqua;
        width: 100%;
        height: 100%;
    }
  }
</style>